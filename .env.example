# Database (Prisma, used by the running dev app)
DATABASE_URL=postgresql://noteapp:changeme@localhost:5432/notes_dev

# Database (Supertest integration tests only — never the dev database)
TEST_DATABASE_URL=postgresql://noteapp:changeme@localhost:5432/notes_test

# Auth — JWT signing secret, HS256, must be at least 32 characters
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long

# CORS — exact origin of the frontend dev server
WEB_ORIGIN=http://localhost:5173

# Frontend — base URL of the API the web app talks to
VITE_API_URL=http://localhost:3001

# Server
NODE_ENV=development
PORT=3001

# Auth — bcrypt cost factor (optional, defaults to 12 if unset)
BCRYPT_ROUNDS=12

# Scheduled purge jobs — cron schedule (optional, defaults documented in lib/jobs if unset)
PURGE_CRON_SCHEDULE=0 3 * * *

# Docker Compose Postgres provisioning — must match DATABASE_URL above
POSTGRES_USER=noteapp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notes_dev
POSTGRES_PORT=5432

# Context7 MCP — optional. Unauthenticated free tier is used by default; set this to upgrade.
# CONTEXT7_API_KEY=
