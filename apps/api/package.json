    "pino-http": "11.0.0",
    "helmet": "8.2.0",
    "cors": "2.8.6",
    "cookie-parser": "1.4.7",
    "express-rate-limit": "8.5.2"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "prisma": "6.19.3",
    "dotenv-cli": "11.0.0",
    "vitest": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "supertest": "7.2.2",
    "@types/supertest": "7.2.0",
    "tsx": "4.22.4",
    "@types/node": "26.1.1",
    "@types/express": "5.0.6",
    "@types/cors": "2.8.19",
