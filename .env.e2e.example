# Playwright E2E journey test environment (AB-1016).
# Copy this file to `.env.e2e` (gitignored) before running the journey spec.
# Deliberately isolated from the ordinary dev stack: points at notes_test
# (never notes_dev) and uses ports distinct from `pnpm dev` (3001/5173) so
# Playwright's `reuseExistingServer` can never silently attach to a real
# dev session instead of this dedicated e2e one.

# Database (Prisma, used ONLY by the e2e API process — points at the
# disposable notes_test database, never notes_dev)
DATABASE_URL=postgresql://noteapp:changeme@localhost:5432/notes_test

# Auth — JWT signing secret, HS256, must be at least 32 characters
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long

# CORS — origin of the e2e web dev server (not the ordinary 5173)
WEB_ORIGIN=http://localhost:5174

# Frontend — base URL of the e2e API server (not the ordinary 3001)
VITE_API_URL=http://localhost:3002

# Server
NODE_ENV=development
PORT=3002

# Auth — bcrypt cost factor (optional, defaults to 12 if unset)
BCRYPT_ROUNDS=4

# Test-only rate-limit bypass — never set this in .env/.env.example.
# See apps/api/src/middleware/rateLimit.ts.
E2E_DISABLE_RATE_LIMIT=true
